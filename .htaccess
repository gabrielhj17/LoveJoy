<IfModule mod_headers.c>
# Content Security Policy
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src https://www.google.com;"
    
# Prevent clickjacking
Header set X-Frame-Options "SAMEORIGIN"
    
# Prevent MIME type sniffing
Header set X-Content-Type-Options "nosniff"
    
# Enable XSS protection
Header set X-XSS-Protection "1; mode=block"
    
# Referrer policy
Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(env|ini|log|sh|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>